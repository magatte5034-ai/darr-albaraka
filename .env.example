# ============================================================
#  Darr-Albaraka — Environment Variables Template
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ============================================================

# Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Google OAuth — Client ID only (secret stays in Supabase dashboard)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# App
VITE_APP_URL=https://<your-production-domain>
VITE_SITE_NAME=Darr-Albaraka

# WhatsApp business number (international format)
VITE_WHATSAPP_NUMBER=+221777975034

# PayTech — Paiement en ligne (Wave, Orange Money, Carte bancaire)
# Créez votre compte marchand sur https://paytech.sn
VITE_PAYTECH_API_KEY=<votre-api-key-paytech>
VITE_PAYTECH_API_SECRET=<votre-api-secret-paytech>
# Environnement : "test" pour les tests, "prod" pour la production
VITE_PAYTECH_ENV=test
